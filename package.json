{
  "name": "perfin",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test": "vitest",
    "tsbuild": "tsc -p tsconfig.app.json",
    "build": "tsc -p tsconfig.app.json && vite build",
    "preview": "vite preview",
    "cftypes": "wrangler types server/cloudflare.d.ts && prettier -w server/cloudflare.d.ts",
    "migration:generate": "drizzle-kit generate",
    "migration:create": "wrangler d1 migrations create perfin-staging $(pnpm dlx human-id a l 0 _)",
    "migration:apply": "wrangler d1 migrations apply perfin-staging --local",
    "migration:apply-staging": "wrangler d1 migrations apply perfin-staging --remote",
    "runsql": "wrangler d1 execute perfin-staging --local --command",
    "runsqlfile": "wrangler d1 execute perfin-staging --local --file",
    "deploy:staging": "wrangler --env staging d1 migrations apply perfin-staging --remote & wrangler --env staging deploy --keep-vars",
    "deploy:production": "wrangler --env production d1 migrations apply perfin --remote & wrangler --env production deploy --keep-vars"
  },
  "dependencies": {
    "@block65/webcrypto-web-push": "^1.0.2",
    "@headlessui/react": "^2.2.10",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.2",
    "@tanstack/react-form": "^1.33.1",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.170.17",
    "@trpc/client": "^11.18.0",
    "@trpc/server": "^11.18.0",
    "@trpc/tanstack-react-query": "^11.18.0",
    "@types/node": "^26.1.1",
    "@vis.gl/react-google-maps": "^1.9.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "drizzle-orm": "1.0.0-beta.4-4605abe",
    "itty-router": "^5.0.24",
    "lucide-react": "^1.24.0",
    "magic-bytes.js": "^1.13.0",
    "nanoid": "^5.1.16",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0",
    "ua-parser-js": "^2.0.10",
    "zod": "^4.4.3",
    "zod-form-data": "^3.0.2"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.44.0",
    "@cloudflare/vitest-pool-workers": "^0.18.4",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/router-plugin": "^1.168.19",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "daisyui": "^5.6.16",
    "drizzle-kit": "1.0.0-beta.4-4605abe",
    "esbuild": "^0.28.1",
    "globals": "^17.7.0",
    "nanoid": "^5.1.5",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.2",
    "typescript": "~7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0",
    "zocker": "^3.0.0"
  },
  "packageManager": "pnpm@11.11.0+sha512.4463f65fd80ed80d69bc1d4bf163ee94f605c7380fc318bb5b2ebe15f8cd12d49c51a4d59e951b401e764d3b6ca751cbf51bc50ed7001a6bcb4935e684c34882"
}
