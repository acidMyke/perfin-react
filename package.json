{
  "name": "perfin",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.app.json && vite build",
    "preview": "vite preview",
    "cftypes": "wrangler types server/cloudflare.d.ts && prettier -w server/cloudflare.d.ts",
    "migration:generate": "drizzle-kit generate",
    "migration:create": "wrangler d1 migrations create perfin-staging $(pnpm dlx human-id a l 0 _)",
    "migration:apply": "wrangler d1 migrations apply perfin-staging --local",
    "migration:apply-staging": "wrangler d1 migrations apply perfin-staging --remote",
    "runsql": "wrangler d1 execute perfin-staging --local --command",
    "runsqlfile": "wrangler d1 execute perfin-staging --local --file",
    "deploy:staging": "wrangler --env staging d1 migrations apply perfin-staging --remote & wrangler --env staging deploy --keep-vars",
    "deploy:production": "wrangler --env production d1 migrations apply perfin --remote & wrangler --env production deploy --keep-vars"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.10",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "@tanstack/react-form": "^1.29.0",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-router": "^1.168.18",
    "@trpc/client": "^11.16.0",
    "@trpc/server": "^11.16.0",
    "@trpc/tanstack-react-query": "^11.16.0",
    "@types/node": "^25.6.0",
    "@vis.gl/react-google-maps": "^1.8.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "1.0.0-beta.20",
    "itty-router": "^5.0.23",
    "lucide-react": "^1.8.0",
    "nanoid": "^5.1.7",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "ua-parser-js": "^2.0.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.31.2",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/router-plugin": "^1.167.18",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "daisyui": "^5.5.19",
    "drizzle-kit": "1.0.0-beta.4-4605abe",
    "eslint": "^10.2.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "nanoid": "^5.1.5",
    "prettier": "^3.8.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.8",
    "wrangler": "^4.81.1"
  },
  "packageManager": "pnpm@10.25.0+sha512.5e82639027af37cf832061bcc6d639c219634488e0f2baebe785028a793de7b525ffcd3f7ff574f5e9860654e098fe852ba8ac5dd5cefe1767d23a020a92f501"
}
